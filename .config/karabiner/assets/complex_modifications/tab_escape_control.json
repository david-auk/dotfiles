{
  "title": "Tab as Escape when tapped, Control when held",
  "rules": [
    {
      "description": "Tab -> Escape if alone, Left Control if held with another key",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "tab",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_control",
              "lazy": true
            }
          ],
          "to_if_alone": [
            {
              "key_code": "escape"
            }
          ],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 200,
            "basic.to_if_held_down_threshold_milliseconds": 150
          }
        }
      ]
    }
  ]
}

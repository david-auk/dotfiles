#!/usr/bin/env bash

set -uo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
LIB_DIR="$SCRIPT_DIR/calendar"

source "$LIB_DIR/common.sh"
source "$LIB_DIR/events.sh"
source "$LIB_DIR/render.sh"
source "$LIB_DIR/details.sh"
source "$LIB_DIR/ui.sh"
source "$LIB_DIR/actions.sh"

ICAL_GUY=$(find_binary ical-guy) || {
  tmux_message "ical-guy was not found"
  exit 0
}

JQ=$(find_binary jq) || {
  tmux_message "jq was not found"
  exit 0
}

FZF=$(find_binary fzf) || {
  tmux_message "fzf was not found"
  exit 0
}

events_file=$(mktemp)
event_rows_file=$(mktemp)

cleanup() {
  rm -f "$events_file" "$event_rows_file"
}

trap cleanup EXIT INT TERM

if ! fetch_today_events >"$events_file"; then
  tmux_message "Could not read calendar events"
  exit 0
fi

event_count=$(count_visible_events "$events_file")

if [ "$event_count" -eq 0 ]; then
  tmux_message "No calendar events today"
  exit 0
fi

build_event_rows "$events_file" >"$event_rows_file"

default_position=$(find_default_event_position "$events_file")

while true; do
  selection=$(select_event "$event_rows_file" "$default_position") || exit 0

  action=${selection%%$'\t'*}
  event_id=${selection#*$'\t'}

  [ -n "$event_id" ] || continue

  # Keep this event selected when returning from the detail screen.
  default_position=$(
    find_event_row_position "$event_rows_file" "$event_id"
  )

  case "$action" in
  ctrl-o)
    if open_event_meeting "$events_file" "$event_id"; then
      exit 0
    fi
    ;;

  enter | "")
    detail_action=$(
      show_event_details "$events_file" "$event_id"
    ) || continue

    if [ "$detail_action" = "ctrl-o" ]; then
      if open_event_meeting "$events_file" "$event_id"; then
        exit 0
      fi
    fi
    ;;
  esac
done
